# ============================================
# ASKLY — Environment Configuration
# Rename this file to .env.local and fill in your values
# ============================================

# --- Supabase Configuration ---
# Get these from your Supabase project: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- App Configuration ---
# Set to your production URL for Vercel deployments, or http://localhost:3000 for local dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
